    <RootNamespace>ProbeB.Gen</RootNamespace>
    <AssemblyName>ProbeB.Gen</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
