<Project Sdk="Microsoft.NET.Sdk">

  <!-- Proves BOTH emitted handlers build + run as a unit against the real providers. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Proof</RootNamespace>
    <AssemblyName>proof</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Main.cs" />
    <Compile Include="..\emitted\AddPoints.Repository.Handler.cs" Link="emitted\AddPoints.Repository.Handler.cs" />
    <Compile Include="..\emitted\AddPoints.BucketStore.Handler.cs" Link="emitted\AddPoints.BucketStore.Handler.cs" />
    <Compile Include="..\src\Store.cs" Link="src\Store.cs" />
    <Compile Include="..\src\Domain.cs" Link="src\Domain.cs" />
  </ItemGroup>

</Project>
