<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ProbeD</RootNamespace>
    <AssemblyName>probe-d</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Same Roslyn the rest of the spike uses (spike/gen, probe-a). Here it is a normal
         runtime dependency of a console tool, not an analyzer: we build a Compilation, ask
         the semantic model for ITypeSymbols, and render them via ToDisplayString. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.11.0" />
  </ItemGroup>

</Project>
