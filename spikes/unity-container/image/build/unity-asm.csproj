<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net471</TargetFramework>
    <LangVersion>9.0</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyName>$(AsmName)</AssemblyName>
    <DefineConstants>UNITY_2022_3_50;UNITY_2022_3;UNITY_2022;UNITY_5_3_OR_NEWER;UNITY_2022_3_OR_NEWER;UNITY_64;UNITY_EDITOR;UNITY_EDITOR_WIN;UNITY_STANDALONE;UNITY_INCLUDE_TESTS;ENABLE_LEGACY_INPUT_MANAGER;CSHARP_7_3_OR_NEWER;$(ExtraDefines)</DefineConstants>
    <NoWarn>$(NoWarn);CS1701;CS1702</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(SrcGlob)" />
    <Reference Include="$(UnityManaged)/UnityEngine/*.dll" Private="false" />
    <Reference Include="$(ProjectLibrary)/ScriptAssemblies/*.dll"
              Exclude="$(ProjectLibrary)/ScriptAssemblies/$(AsmName).dll"
              Private="false" />
  </ItemGroup>

</Project>
