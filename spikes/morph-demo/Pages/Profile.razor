@page "/profile"
@namespace MorphDemo.Pages

<MorphRaised Class="page-head">
    <h1 class="page-title">Profile</h1>
    <p class="page-sub">One deep tree — depth-3 stagger inside a single route.</p>
</MorphRaised>

<MorphRaised Class="card">
    <div class="row">
        <MorphInset Class="circle big">JD</MorphInset>
        <div class="col">
            <h2>Jordan Doe</h2>
            <span class="muted">depth-0 hero · nested sections below</span>
        </div>
    </div>

    <MorphInset Class="inner">
        <strong>About</strong>
        <p class="lead">A nested inset section (depth 1) that carries its own nested leaf.</p>
        <MorphRaised Class="leaf">
            <span>depth-2 raised leaf</span>
            <MorphInset Class="leaf small">depth-3 inset leaf</MorphInset>
        </MorphRaised>
    </MorphInset>

    <MorphInset Class="inner">
        <strong>Media</strong>
        <img class="thumb neu-raised" src="@Banner" alt="banner" />
        <div class="btn-row">
            <button class="btn primary">Follow</button>
            <button class="btn">Message</button>
        </div>
    </MorphInset>
</MorphRaised>

@code {
    private const string Banner =
        "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 320 100'%3E%3Crect width='320' height='100' fill='%234a9e57'/%3E%3Cpolygon points='60,76 96,34 132,76' fill='%23fdf7ec' fill-opacity='.85'/%3E%3Ccircle cx='210' cy='44' r='18' fill='%23d39a2c'/%3E%3Crect x='250' y='30' width='46' height='40' rx='8' fill='%235d8cf0'/%3E%3C/svg%3E";
}
