@page "/dashboard"
@namespace MorphDemo.Pages

<h1 class="page-title">Dashboard</h1>
<p class="page-sub">The interactive paths: in-page swaps and async load / error.</p>

<div class="grid">
    <MorphInset Class="tile">
        <div class="stat-num">42</div>
        <div class="stat-label">open</div>
    </MorphInset>
    <MorphInset Class="tile">
        <div class="stat-num">7</div>
        <div class="stat-label">failing</div>
    </MorphInset>
</div>

<h2 class="section">Variable style · MorphSurface</h2>
<button class="swap" @onclick="ToggleStyle">Style: @_style</button>
<MorphSurface Style="_style" Class="card">
    <h2>Same component, switchable look</h2>
    <p class="muted">One MorphSurface, dispatched to @_style via a type-safe switch — no DynamicComponent.</p>
</MorphSurface>

<h2 class="section">In-page swap · MorphStage</h2>
<button class="swap" @onclick="Toggle">Swap layout (now @(_view == 0 ? "A" : "B"))</button>

<MorphStage Screen="_view" Context="v">
    @if (v == 0)
    {
        <MorphRaised Class="card">
            <h2>Layout A</h2>
            <div class="row">
                <MorphInset Class="circle">A</MorphInset>
                <MorphInset Class="inner">
                    <span class="muted">circle + inset, siblings</span>
                </MorphInset>
            </div>
        </MorphRaised>
    }
    else
    {
        <MorphInset Class="card">
            <h2>Layout B</h2>
            <MorphRaised Class="inner">
                <span>raised inner</span>
                <MorphInset Class="leaf">depth-2 inset leaf</MorphInset>
            </MorphRaised>
        </MorphInset>
    }
</MorphStage>

<h2 class="section">Async load · Loading / Error</h2>
<div class="btn-row">
    <button class="swap" @onclick="LoadFast">Load fast</button>
    <button class="swap" @onclick="LoadSlow">Load slow (times out)</button>
</div>

<MorphStage Screen="_loadKey" Load="LoadAsync">
    <ChildContent Context="k">
        <MorphRaised Class="card">
            <h2>Loaded item #@k</h2>
            <p class="muted">Swapped in after the async gate resolved.</p>
        </MorphRaised>
    </ChildContent>
    <LoadingContent>
        <div class="status">loading…</div>
    </LoadingContent>
    <ErrorContent Context="ex">
        <div class="status error">@ex.Message</div>
    </ErrorContent>
</MorphStage>

@code {
    private int _view;
    private int _loadKey;
    private bool _slowNext;
    private MorphStyle _style = MorphStyle.Raised;

    private void ToggleStyle() =>
        _style = _style == MorphStyle.Raised ? MorphStyle.Inset : MorphStyle.Raised;

    private void Toggle() => _view = _view == 0 ? 1 : 0;

    private void LoadFast()
    {
        _slowNext = false;
        _loadKey++;
    }

    private void LoadSlow()
    {
        _slowNext = true;
        _loadKey++;
    }

    private async Task LoadAsync(int key) => await Task.Delay(_slowNext ? 3000 : 200);
}
