@page "/dashboard"
@namespace MorphDemo.Pages

<MorphRaised Class="page-head">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-sub">The interactive paths: in-page swaps and async load / error.</p>
</MorphRaised>

<div class="grid">
    <MorphInset Class="tile">
        <div class="stat-num">42</div>
        <div class="stat-label">open</div>
    </MorphInset>
    <MorphInset Class="tile">
        <div class="stat-num">7</div>
        <div class="stat-label">failing</div>
    </MorphInset>
</div>

<MorphRaised Class="section-head">
    <h2 class="section">Variable style · MorphSurface</h2>
    <button class="swap" @onclick="ToggleStyle">Style: @_style</button>
</MorphRaised>
<MorphSurface Style="_style" Class="card">
    <h2>Same component, switchable look</h2>
    <p class="muted">One MorphSurface, dispatched to @_style via a type-safe switch — no DynamicComponent.</p>
</MorphSurface>

<MorphRaised Class="section-head">
    <h2 class="section">Cut-out · open &amp; close</h2>
    <button class="swap" @onclick="ToggleCut">Reopen (panel @(_cut + 1))</button>
</MorphRaised>
<MorphStage Screen="_cut" Context="c">
    <MorphCutout Class="cutout-panel">
        <div class="cutout-body">
            <div class="cutout-head">
                <strong>Panel @(c + 1)</strong>
                <span>opens from a point</span>
            </div>
            <div class="cutout-grid">
                <div class="cutout-tile"><b>@(c == 0 ? "14" : "27")</b><span>runs</span></div>
                <div class="cutout-tile"><b>86%</b><span>success</span></div>
            </div>
        </div>
    </MorphCutout>
</MorphStage>

<MorphRaised Class="section-head">
    <h2 class="section">Thin cut-out · slim bar</h2>
    <button class="swap" @onclick="ToggleThin">Reopen (bar @(_thin + 1))</button>
</MorphRaised>
<MorphStage Screen="_thin" Context="t">
    <MorphCutout Class="cutout-thin">
        <div class="cutout-bar">
            <strong>Bar @(t + 1)</strong>
            <span>@(t == 0 ? "idle" : "running")</span>
        </div>
    </MorphCutout>
</MorphStage>

<MorphRaised Class="section-head">
    <h2 class="section">Thin + wide cut-out · floor gap at the end-caps (bug)</h2>
    <button class="swap" @onclick="ToggleWide">Reopen (bar @(_wide + 1))</button>
</MorphRaised>
<MorphStage Screen="_wide" Context="w">
    <MorphCutout Class="cutout-wide">
        <div class="cutout-bar">
            <strong>Bar @(w + 1)</strong>
            <span>@(w == 0 ? "idle" : "running")</span>
        </div>
    </MorphCutout>
</MorphStage>

<MorphRaised Class="section-head">
    <h2 class="section">Cut-out · content colour &amp; nested surface</h2>
</MorphRaised>
<MorphCutout Class="card">
    <h2>Readable on the floor</h2>
    <p class="muted">Generic content inherits light text from the cut-out surface — no per-element override.</p>
    <MorphInset Class="inner">
        <strong>Nested inset</strong>
        <p class="muted">Dark here: the light text stops at the nested surface, not leaking in.</p>
    </MorphInset>
</MorphCutout>

<MorphRaised Class="section-head">
    <h2 class="section">In-page swap · MorphStage</h2>
    <button class="swap" @onclick="Toggle">Swap layout (now @(_view == 0 ? "A" : "B"))</button>
</MorphRaised>

<MorphStage Screen="_view" Context="v">
    @if (v == 0)
    {
        <MorphRaised Class="card">
            <h2>Layout A</h2>
            <div class="row">
                <MorphInset Class="circle">A</MorphInset>
                <MorphInset Class="inner">
                    <span class="muted">circle + inset, siblings</span>
                </MorphInset>
            </div>
        </MorphRaised>
    }
    else
    {
        <MorphInset Class="card">
            <h2>Layout B</h2>
            <MorphRaised Class="inner">
                <span>raised inner</span>
                <MorphInset Class="leaf">depth-2 inset leaf</MorphInset>
            </MorphRaised>
        </MorphInset>
    }
</MorphStage>

<MorphRaised Class="section-head">
    <h2 class="section">Loading dynamics · pre-state</h2>
    <div class="btn-row">
        <button class="swap" @onclick="Remount">Remount (initial)</button>
        <button class="swap" @onclick="ReloadSlow">Reload (slow → pre)</button>
        <button class="swap" @onclick="ReloadInstant">Reload (instant)</button>
    </div>
</MorphRaised>

@if (_mounted)
{
    <MorphStage Screen="_loadKey" Load="LoadAsync">
        <ChildContent Context="k">
            <MorphRaised Class="card">
                <h2>Item #@k</h2>
                <p class="muted">Loaded? extrude. Not loaded? lie flat, wait, rise.</p>
            </MorphRaised>
        </ChildContent>
        <ErrorContent Context="ex">
            <div class="status error">@ex.Message</div>
        </ErrorContent>
    </MorphStage>
}

@code {
    private int _view;
    private int _loadKey;
    private bool _mounted = true;
    private bool _instantNext;
    private MorphStyle _style = MorphStyle.Raised;
    private int _cut;

    private void ToggleStyle() => _style = _style switch
    {
        MorphStyle.Raised => MorphStyle.Inset,
        MorphStyle.Inset => MorphStyle.Cutout,
        _ => MorphStyle.Raised,
    };

    private void ToggleCut() => _cut = _cut == 0 ? 1 : 0;

    private int _thin;

    private void ToggleThin() => _thin = _thin == 0 ? 1 : 0;

    private int _wide;

    private void ToggleWide() => _wide = _wide == 0 ? 1 : 0;

    private void Toggle() => _view = _view == 0 ? 1 : 0;

    private async Task Remount()
    {
        _mounted = false;
        StateHasChanged();
        await Task.Delay(60);
        _instantNext = false;
        _mounted = true;
    }

    private void ReloadSlow()
    {
        _instantNext = false;
        _loadKey++;
    }

    private void ReloadInstant()
    {
        _instantNext = true;
        _loadKey++;
    }

    private async Task LoadAsync(int key)
    {
        if (_instantNext)
            return;

        await Task.Delay(1100);
    }
}
