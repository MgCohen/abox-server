@page "/"
@namespace MorphDemo.Pages

<h1 class="page-title">Gallery</h1>
<p class="page-sub">Every shape, size, and nesting depth on one screen — eyeball any transition without rebuilding.</p>

<div class="grid">
    <MorphShape Class="neu-raised card">
        <h2>Raised card</h2>
        <p class="lead">A flat depth-0 panel: a heading and a line of copy, so you can see text ride the morph.</p>
    </MorphShape>

    <MorphShape Class="neu-inset card">
        <h2>Inset card</h2>
        <p class="muted">Two muted lines —</p>
        <p class="muted">— pressed into the surface.</p>
    </MorphShape>

    <MorphShape Class="neu-raised card">
        <h2>Nested · depth 2</h2>
        <MorphShape Class="neu-inset inner">
            <span class="muted">inner · inset</span>
            <MorphShape Class="neu-raised leaf">leaf · raised</MorphShape>
        </MorphShape>
    </MorphShape>

    <MorphShape Class="neu-raised card">
        <div class="row">
            <MorphShape Class="neu-inset circle">MC</MorphShape>
            <div class="col">
                <strong>Avatar row</strong>
                <span class="muted">round shape, nested one deep</span>
            </div>
        </div>
        <div>
            <span class="chip">tag</span>
            <span class="chip">pill chip</span>
        </div>
    </MorphShape>

    <MorphShape Class="neu-inset tile">
        <div class="stat-num">128</div>
        <div class="stat-label">flat stat tile</div>
    </MorphShape>

    <MorphShape Class="neu-raised card">
        <img class="thumb neu-inset" src="@SwatchA" alt="swatch" />
        <span class="muted">image + caption</span>
    </MorphShape>

    <MorphShape Class="neu-raised card wide">
        <div class="spread">
            <div class="col">
                <strong>Wide panel</strong>
                <span class="muted">spans the grid; the buttons are content, not shapes</span>
            </div>
            <div class="btn-row">
                <button class="btn">Secondary</button>
                <button class="btn primary">Primary</button>
            </div>
        </div>
    </MorphShape>
</div>

@code {
    private const string SwatchA =
        "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 100'%3E%3Crect width='160' height='100' fill='%236c5ce7'/%3E%3Ccircle cx='52' cy='52' r='26' fill='%23fdf7ec' fill-opacity='.85'/%3E%3Crect x='96' y='30' width='44' height='42' rx='9' fill='%235d8cf0'/%3E%3C/svg%3E";
}
