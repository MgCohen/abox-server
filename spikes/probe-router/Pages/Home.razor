@page "/"
<PageTitle>Probe — Home</PageTitle>

<h1 class="morph-item" style="--i:0">Home route</h1>

<div class="kpi-row">
    <div class="kpi neu-raised morph-item" style="--i:1">
        <span class="kpi-label">Active runs</span>
        <span class="kpi-value">7</span>
    </div>
    <div class="kpi neu-raised morph-item" style="--i:2">
        <span class="kpi-label">Agents</span>
        <span class="kpi-value green">3</span>
    </div>
    <div class="kpi neu-raised morph-item" style="--i:3">
        <span class="kpi-label">Flows</span>
        <span class="kpi-value">12</span>
    </div>
    <div class="kpi neu-raised morph-item" style="--i:4">
        <span class="kpi-label">Queue</span>
        <span class="kpi-value">2</span>
    </div>
</div>

<div class="card neu-raised morph-item" style="--i:5">
    <div class="card-head"><h2>HOME card</h2></div>
    <p class="attention-body">This is the <code>/</code> route. Cards here carry <code>.morph-item</code>.</p>
    <p class="attention-body">
        <a href="/detail" class="btn-outline sm">&lt;a&gt; link to /detail</a>
    </p>
</div>
