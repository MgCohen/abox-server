# General
node_modules/
*.log

# Build artifacts (MSBuild per-project output dirs — present at
# remote-agents-dotnet/artifacts/ and ui/artifacts/)
artifacts/
**/artifacts/

# Default MSBuild output (spikes using the standard bin/obj layout)
bin/
obj/

# Claude Code project state (per-user: launch.json, settings.local.json).
# Shared project assets under these dirs are checked in; everything else
# directly under .claude/ (settings.local.json, session state) stays ignored.
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/workflows/

# Visual Studio per-user IDE state
.vs/
