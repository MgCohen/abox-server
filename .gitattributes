# Enforcer files MUST stay LF. They run as POSIX sh on Linux CI runners; a CRLF
# byte breaks shebang parsing and line matching. Pinning eol=lf here stops a
# Windows checkout (autocrlf) from committing CRLF and silently breaking a guard.
# See governance/policy/protected-paths (ADR 0010 / 0012 / 0014).
*.sh                              text eol=lf
*.yml                             text eol=lf
*.yaml                            text eol=lf
governance/policy/protected-paths text eol=lf
.github/CODEOWNERS                text eol=lf
governance/harness/hooks/*        text eol=lf
