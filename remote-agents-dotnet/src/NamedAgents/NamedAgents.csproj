<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Flows.Agents</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\RemoteAgents\RemoteAgents.csproj" />
  </ItemGroup>

  <!-- Prompts are NOT embedded. Prompts.Load(name) walks up from CWD /
       AppContext.BaseDirectory to find `remote-agents-dotnet/src/NamedAgents/
       prompts/<name>.md` and reads it at every call, so editing a .md picks
       up on the next agent run with no rebuild. -->

</Project>
