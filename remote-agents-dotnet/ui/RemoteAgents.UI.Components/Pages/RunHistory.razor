@page "/runs"
@inject HostApiClient Api
@inject NavigationManager Nav

<PageTitle>Runs</PageTitle>

<div class="page">
    <h1>Runs</h1>
    <p><NavLink href="">← New run</NavLink></p>

    @if (_runs is null)
    {
        <p>Loading…</p>
    }
    else if (_runs.Length == 0)
    {
        <p>No runs yet.</p>
    }
    else
    {
        <table class="runs">
            <thead>
                <tr>
                    <th>Started</th>
                    <th>Project</th>
                    <th>Flow</th>
                    <th>Status</th>
                    <th>Prompt</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _runs)
                {
                    <tr @onclick="@(() => Nav.NavigateTo($"runs/{r.Id}"))" class="row">
                        <td title="@r.StartedAt">@FormatLocal(r.StartedAt)</td>
                        <td>@r.Project</td>
                        <td>@r.Flow</td>
                        <td><span class="status status-@r.Status.ToLowerInvariant()">@r.Status</span></td>
                        <td class="prompt">@Truncate(r.Prompt, 80)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private RunSummary[]? _runs;

    protected override async Task OnInitializedAsync()
    {
        _runs = await Api.GetRunsAsync();
    }

    private static string FormatLocal(DateTimeOffset t) => t.ToLocalTime().ToString("MMM dd HH:mm:ss");

    private static string Truncate(string s, int n) =>
        s.Length <= n ? s : s[..n] + "…";
}
