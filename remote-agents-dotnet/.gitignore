# Canonical build output: centralized via Directory.Build.props
# (UseArtifactsOutput=true) — `dotnet build` writes everything here.
/artifacts/

# Fallback catch-alls: vstest (`dotnet test`) doesn't fully honor
# UseArtifactsOutput and creates per-project bin/obj as a test-host
# working dir. Same for some VS / Rider workflows.
**/bin/
**/obj/

# Runtime sessions only — anchored to the root so it doesn't shadow the
# Core/Sessions source namespace directory.
/sessions/
/scratch/
*.user
.vs/
