@page "/runs/{Id:guid}"
@implements IAsyncDisposable
@inject HostApiClient Api
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Run @Id</PageTitle>

<div class="page run-view">
    <p><NavLink href="runs">← Runs</NavLink></p>

    @if (_snap is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <h1>@_snap.Flow</h1>
        <p class="meta">
            <span class="status status-@_snap.Phase.ToString().ToLowerInvariant()">@_snap.Phase</span>
            <span class="muted">@_snap.Project</span>
            <span class="muted">v@_snap.Version</span>
            @if (IsActive(_snap.Phase))
            {
                <button class="cancel" @onclick="CancelAsync">Cancel</button>
            }
        </p>

        <h2>Steps</h2>
        @if (_snap.Steps.Count == 0)
        {
            <p class="hint">No steps yet.</p>
        }
        else
        {
            <ol class="steps">
                @foreach (var step in _snap.Steps)
                {
                    <li class="step status-@step.Status.ToString().ToLowerInvariant()">
                        <span class="step-name">@step.Name</span>
                        <span class="step-status">@step.Status</span>
                        <span class="step-time">@TimeRange(step)</span>
                        @if (!string.IsNullOrEmpty(step.Summary))
                        {
                            <pre class="step-summary">@step.Summary</pre>
                        }
                        @if (!string.IsNullOrEmpty(step.Error))
                        {
                            <pre class="step-error">@step.Error</pre>
                        }
                    </li>
                }
            </ol>
        }
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private FlowSnapshot? _snap;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _snap = await Api.GetFlowAsync(Id);
        if (_snap is null)
        {
            Nav.NavigateTo("runs");
            return;
        }

        // Stream live updates only while the run is active. A finished run already
        // has its complete final snapshot — no SSE needed.
        if (IsActive(_snap.Phase))
        {
            _cts = new CancellationTokenSource();
            _ = ConsumeAsync(_cts.Token);
        }
    }

    private async Task ConsumeAsync(CancellationToken ct)
    {
        var client = new FlowStreamClient(Http);
        try
        {
            await foreach (var snap in client.StreamAsync(Id, ct))
            {
                _snap = snap;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private Task CancelAsync() => Api.CancelFlowAsync(Id);

    private static string TimeRange(StepDto step)
    {
        var started = step.StartedAt?.ToLocalTime().ToString("HH:mm:ss") ?? "—";
        return step.EndedAt is { } e ? $"{started} → {e.ToLocalTime():HH:mm:ss}" : started;
    }

    private static bool IsActive(FlowPhase phase) =>
        phase is FlowPhase.Pending or FlowPhase.Running or FlowPhase.Paused;

    public ValueTask DisposeAsync()
    {
        try { _cts?.Cancel(); } catch { /* already disposed */ }
        _cts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
