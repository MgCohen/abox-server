@page "/runs"
@inject HostApiClient Api
@inject NavigationManager Nav

<PageTitle>Runs</PageTitle>

<div class="page">
    <h1>Runs</h1>

    @if (_runs is null)
    {
        <p>Loading…</p>
    }
    else if (_runs.Length == 0)
    {
        <p>No runs yet. <NavLink href="">Start one →</NavLink></p>
    }
    else
    {
        <table class="runs">
            <thead>
                <tr>
                    <th>Started</th>
                    <th>Flow</th>
                    <th>Project</th>
                    <th>Phase</th>
                    <th>Steps</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _runs)
                {
                    <tr class="row" @onclick="@(() => Nav.NavigateTo($"runs/{r.Id}"))">
                        <td title="@r.CreatedAt">@FormatLocal(r.CreatedAt)</td>
                        <td>@r.Flow</td>
                        <td>@r.Project</td>
                        <td><span class="status status-@r.Phase.ToString().ToLowerInvariant()">@r.Phase</span></td>
                        <td>@StepSummary(r)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private FlowSnapshot[]? _runs;

    protected override async Task OnInitializedAsync() =>
        _runs = await Api.GetFlowsAsync();

    private static string StepSummary(FlowSnapshot s)
    {
        if (s.Steps.Count == 0) return "(pending)";
        var done = s.Steps.Count(x => x.Status == StepStatus.Completed);
        return $"{done}/{s.Steps.Count} · last: {s.Steps[^1].Name}";
    }

    private static string FormatLocal(DateTimeOffset t) =>
        t.ToLocalTime().ToString("MMM dd HH:mm:ss");
}
