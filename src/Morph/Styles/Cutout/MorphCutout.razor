@namespace Morph
@inject MorphOptions Options

<MorphShape Class="@($"neu-cutout {Class}")" Vars="@Options.Resolve(CutoutStyle.Name).Vars">
    <div class="@($"cutout-floor {Class}")">@ChildContent</div>
    <div class="cutout-ring"></div>
</MorphShape>

@code {
    [Parameter] public string? Class { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
