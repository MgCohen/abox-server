@namespace Morph
@typeparam TKey
@inherits MorphStageBase

<div class="morph-stage" data-phase="@DataPhase" style="@Options.AllVars;--max-depth:@MaxDepth" @ref="StageElement" @onmorphend="OnAnimationEnd">
    <CascadingValue Value="RootContext" IsFixed="true">
        <div @key="_current" class="morph-screen">
            @ChildContent(_current)
        </div>
    </CascadingValue>
</div>
@if (Phase == MorphPhase.Loading && LoadingContent is not null)
{
    <div class="morph-loader">@LoadingContent</div>
}
@if (LoadError is not null && ErrorContent is not null)
{
    <div class="morph-error">@ErrorContent(LoadError)</div>
}

@code {
    [Parameter, EditorRequired] public TKey Screen { get; set; } = default!;

    [Parameter, EditorRequired] public RenderFragment<TKey> ChildContent { get; set; } = default!;

    [Parameter] public Func<TKey, Task>? Load { get; set; }

    [Parameter] public RenderFragment? LoadingContent { get; set; }

    [Parameter] public RenderFragment<Exception>? ErrorContent { get; set; }

    private TKey _current = default!;
    private TKey _requested = default!;
    private bool _initialized;

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized)
        {
            _current = Screen;
            _requested = Screen;
            _initialized = true;
            return;
        }

        if (EqualityComparer<TKey>.Default.Equals(Screen, _requested))
            return;

        _requested = Screen;
        var target = Screen;
        await TransitionAsync(
            Load is null ? null : () => Load(target),
            () => _current = target);
    }
}
