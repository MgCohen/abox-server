@namespace Morph
@inherits MorphStageBase
@implements IDisposable

<div class="morph-stage" data-phase="@DataPhase" style="--max-depth:@MaxDepth" @ref="StageElement">
    <CascadingValue Value="RootContext" IsFixed="true">
        @Body
    </CascadingValue>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [Parameter, EditorRequired] public RenderFragment? Body { get; set; }

    private IDisposable? _registration;
    private bool _awaitingEnter;

    protected override void OnInitialized()
    {
        _registration = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        Nav.LocationChanged += OnLocationChanged;
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (string.Equals(context.TargetLocation, Nav.Uri, StringComparison.Ordinal))
            return;

        if (await RunPhaseAsync(MorphPhase.Exiting))
        {
            ResetDepth();
            _awaitingEnter = true;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args) => _ = EnterAsync();

    private async Task EnterAsync()
    {
        if (!_awaitingEnter)
            return;

        _awaitingEnter = false;
        if (await RunPhaseAsync(MorphPhase.Entering))
            Settle();
    }

    public void Dispose()
    {
        _registration?.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
