<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <!-- A library, not a suite: it carries the [Rule] attribute + ParityGuard for the test projects to
         reference. The xunit package would otherwise flag it as a test project and the runner would try
         (and fail) to discover tests in it. -->
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit" Version="2.9.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- The Meta self-suite nests here (it polices adherence to this engine), but is its own test assembly —
       keep its sources out of this library's default compile glob. -->
  <ItemGroup>
    <Compile Remove="Meta/**/*.cs" />
  </ItemGroup>

</Project>
