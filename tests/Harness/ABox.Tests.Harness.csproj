<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <!-- A library, not a suite: it carries the [Rule] attribute + ParityGuard for the test projects to
         reference. The xunit package would otherwise flag it as a test project and the runner would try
         (and fail) to discover tests in it. -->
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit" Version="2.9.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- The harness's own tests nest here (they police adherence to this engine), but are their own test
       assembly — keep their sources out of this library's default compile glob. -->
  <ItemGroup>
    <Compile Remove="Tests/**/*.cs" />
  </ItemGroup>

</Project>
