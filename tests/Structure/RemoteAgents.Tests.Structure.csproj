<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- The two structural test types (Arch, Structure) are sibling folders under this one project, so
         RootNamespace is the shared tests root: Arch\ -> RemoteAgents.Tests.Arch, Structure\ -> .Structure.
         IDE0130 then enforces each file against that. AssemblyName keeps the project's own name. -->
    <RootNamespace>RemoteAgents.Tests</RootNamespace>
    <AssemblyName>RemoteAgents.Tests.Structure</AssemblyName>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
    <PackageReference Include="TngTech.ArchUnitNET" Version="0.13.1" />
    <PackageReference Include="TngTech.ArchUnitNET.xUnit" Version="0.13.1" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
    <Using Include="RemoteAgents.Tests.Harness" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Each type's Rulebook is the source of truth; ParityGuard reads it at runtime. Glob preserves the
       Arch\Rulebook\ / Structure\Rulebook\ prefix in the output so the two never collide. -->
  <ItemGroup>
    <None Include="**\Rulebook\*.md" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Harness\RemoteAgents.Tests.Harness.csproj" />
    <!-- Every production assembly under inspection, by glob: a new feature/slice is governed the moment
         its csproj exists — no edit here, no registration in ArchitectureModel. -->
    <ProjectReference Include="..\..\src\**\RemoteAgents.*.csproj" />
  </ItemGroup>

</Project>
