<Project Sdk="Microsoft.NET.Sdk">

  <!-- Standalone release-versioning CLI (abox-version), deliberately OUT of ABox.slnx like tools/doc-engine
       and tools/hooks. On merge to main it diffs the shipped ABox.Api public surface against the last
       released tag and computes the next SemVer per the owner-decided rules (see README). Reflection-only:
       no target code executes, no network. The tag-gated publish-contracts.yml then publishes. -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>abox-version</AssemblyName>
    <RootNamespace>ABox.Versioning</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Reflection.MetadataLoadContext" Version="9.0.0" />
  </ItemGroup>

  <!-- The tool's co-located tests (Tests/) nest under this project dir; keep them out of the tool's own default
       compile glob — they are a separate test assembly that references the tool, not part of it. -->
  <ItemGroup>
    <Compile Remove="Tests/**/*.cs" />
  </ItemGroup>

</Project>
