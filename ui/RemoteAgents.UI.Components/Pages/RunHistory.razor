@page "/runs"
@inject HostApiClient Api
@inject NavigationManager Nav

<PageTitle>Runs</PageTitle>

<div class="page">
    <h1>Runs</h1>
    <p><NavLink href="">← New run</NavLink></p>

    @if (_flows is null)
    {
        <p>Loading…</p>
    }
    else if (_flows.Length == 0)
    {
        <p>No runs yet.</p>
    }
    else
    {
        <table class="runs">
            <thead>
                <tr>
                    <th>Started</th>
                    <th>Flow</th>
                    <th>Phase</th>
                    <th>Steps</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in _flows)
                {
                    <tr @onclick="@(() => Nav.NavigateTo($"runs/{f.Id}"))" class="row">
                        <td title="@FirstStartedAt(f)">@FormatLocal(FirstStartedAt(f))</td>
                        <td>@f.Name</td>
                        <td><span class="status status-@f.Phase.ToString().ToLowerInvariant()">@f.Phase</span></td>
                        <td class="prompt">@StepSummary(f)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private FlowSnapshot[]? _flows;

    protected override async Task OnInitializedAsync()
    {
        _flows = await Api.GetFlowsAsync();
    }

    private static DateTimeOffset FirstStartedAt(FlowSnapshot s) =>
        s.Steps.Length == 0 ? DateTimeOffset.MinValue : s.Steps[0].StartedAt;

    private static string StepSummary(FlowSnapshot s)
    {
        if (s.Steps.Length == 0) return "(pending)";
        var done = s.Steps.Count(x => x.Status == StepStatus.Completed);
        return $"{done}/{s.Steps.Length} · last: {s.Steps[^1].Name}";
    }

    private static string FormatLocal(DateTimeOffset t) =>
        t == DateTimeOffset.MinValue ? "—" : t.ToLocalTime().ToString("MMM dd HH:mm:ss");
}
