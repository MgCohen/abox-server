@using RemoteAgents.UI.Components.Models

@* One-line tool log entry — overstory-style. Replaces the previous
   stacked ToolUse + ToolResult cards which were collapsed by default
   and required a click for any context. Click the row to expand the
   full input JSON + full result content inline. *@

<div class="tool-row @(_expanded ? "expanded" : "")" @onclick="Toggle">
    <span class="tool-row-time">@Use.At.ToLocalTime().ToString("HH:mm:ss")</span>
    <span class="tool-row-icon">@(Result is { IsError: true } ? "✗" : "⚙")</span>
    <span class="tool-row-name">@Use.ToolName</span>
    <span class="tool-row-summary">@ToolSummary.For(Use.ToolName, Use.InputJson)</span>
    <span class="tool-row-arrow">→</span>
    <span class="tool-row-result @(Result is null ? "pending" : Result.IsError ? "error" : "ok")">
        @if (Result is null)
        {
            <span>…</span>
        }
        else
        {
            @ToolSummary.ResultSummary(Result.Content, Result.IsError)
        }
    </span>
</div>

@if (_expanded)
{
    <div class="tool-row-detail">
        <div class="tool-row-detail-label">input</div>
        <pre class="tool-row-detail-body">@FormatJson(Use.InputJson)</pre>
        @if (Result is not null)
        {
            <div class="tool-row-detail-label">@(Result.IsError ? "error" : "output") (@Result.Content.Length chars)</div>
            <pre class="tool-row-detail-body @(Result.IsError ? "error" : "")">@Result.Content</pre>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public AgentEvent.ToolUse Use { get; set; } = default!;
    [Parameter] public AgentEvent.ToolResult? Result { get; set; }

    private bool _expanded;

    private void Toggle() => _expanded = !_expanded;

    private static string FormatJson(string json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return json; }
    }
}
