@page "/runs/{Id:guid}"
@implements IAsyncDisposable
@inject HostApiClient Api
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Run @Id</PageTitle>

<div class="page run-view">
    <p><NavLink href="runs">← Runs</NavLink></p>

    @if (_snap is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <h1>@_snap.Name</h1>
        <p class="meta">
            <span class="status status-@_snap.Phase.ToString().ToLowerInvariant()">@_snap.Phase</span>
            <span>v@_snap.Version</span>
        </p>

        @if (IsActive(_snap.Phase))
        {
            <button class="cancel" @onclick="CancelAsync">Cancel</button>
        }

        @if (_snap.PendingQuestion is not null)
        {
            <div class="question-modal">
                <h3>Agent needs input</h3>
                <p>@_snap.PendingQuestion</p>
                <input @bind="_answer" placeholder="type a response…" />
                <button @onclick="AnswerAsync" disabled="@(string.IsNullOrWhiteSpace(_answer))">
                    Send
                </button>
            </div>
        }

        <h2>Steps</h2>
        @if (_snap.Steps.Length == 0)
        {
            <p class="hint">No steps yet.</p>
        }
        else
        {
            <ol class="steps">
                @foreach (var step in _snap.Steps)
                {
                    <li class="step status-@step.Status.ToString().ToLowerInvariant()">
                        <span class="step-name">@step.Name</span>
                        <span class="step-status">@step.Status</span>
                        <span class="step-time">
                            @step.StartedAt.ToLocalTime().ToString("HH:mm:ss")
                            @if (step.EndedAt is not null)
                            {
                                <span>→ @step.EndedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                            }
                        </span>
                        @if (!string.IsNullOrEmpty(step.Summary))
                        {
                            <pre class="step-summary">@step.Summary</pre>
                        }
                        @if (!string.IsNullOrEmpty(step.Error))
                        {
                            <pre class="step-error">@step.Error</pre>
                        }
                    </li>
                }
            </ol>
        }
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private FlowSnapshot? _snap;
    private CancellationTokenSource? _cts;
    private string _answer = "";

    protected override async Task OnInitializedAsync()
    {
        _snap = await Api.GetFlowAsync(Id);
        if (_snap is null)
        {
            Nav.NavigateTo("runs");
            return;
        }

        // Stream live updates only while the flow is active. Finished flows
        // already have a complete snapshot — no SSE needed.
        if (IsActive(_snap.Phase))
        {
            _cts = new CancellationTokenSource();
            _ = Task.Run(() => ConsumeAsync(_cts.Token));
        }
    }

    private async Task ConsumeAsync(CancellationToken ct)
    {
        var client = new FlowStreamClient(Http);
        try
        {
            await foreach (var snap in client.StreamAsync(Id, ct))
            {
                _snap = snap;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task CancelAsync()
    {
        await Api.CancelFlowAsync(Id);
    }

    private async Task AnswerAsync()
    {
        if (string.IsNullOrWhiteSpace(_answer)) return;
        await Api.AnswerFlowAsync(Id, _answer);
        _answer = "";
    }

    private static bool IsActive(FlowPhase phase) =>
        phase is FlowPhase.Pending or FlowPhase.Running or FlowPhase.Paused;

    public ValueTask DisposeAsync()
    {
        try { _cts?.Cancel(); } catch { }
        _cts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
