@page "/runs/{Id:guid}"
@using RemoteAgents.UI.Components.Models
@implements IAsyncDisposable
@inject HostApiClient Api
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Run @Id</PageTitle>

<div class="page run-view">
    <p><NavLink href="runs">← Runs</NavLink></p>

    @if (_summary is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <h1>@_summary.Flow <small>on @_summary.Project</small></h1>
        <p class="meta">
            <span class="status status-@_summary.Status.ToString().ToLowerInvariant()">@_summary.Status</span>
            <span>started @_summary.StartedAt.ToLocalTime().ToString("HH:mm:ss")</span>
            @if (_summary.EndedAt is not null)
            {
                <span>· ended @_summary.EndedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
            }
            @if (_summary.ExitCode is not null)
            {
                <span>· exit @_summary.ExitCode</span>
            }
        </p>
        <details>
            <summary>Prompt</summary>
            <pre class="prompt-block">@_summary.Prompt</pre>
        </details>

        @if (IsActive(_summary.Status))
        {
            <button class="cancel" @onclick="CancelAsync">Cancel</button>
        }

        @if (_currentQuestion is not null)
        {
            <div class="question-modal">
                <h3>Agent needs input</h3>
                <p>@_currentQuestion.Text</p>
                <div class="choices">
                    <button @onclick="@(() => RespondAsync("yes"))">Yes</button>
                    <button @onclick="@(() => RespondAsync("no"))">No</button>
                </div>
                <input @bind="_freeformResponse" placeholder="or type a response…" />
                <button @onclick="@(() => RespondAsync(_freeformResponse))" disabled="@(string.IsNullOrWhiteSpace(_freeformResponse))">
                    Send
                </button>
                <p class="hint">v1: response is recorded only — routing into the
                paused agent waits on library v2 (see interaction-modes.md).</p>
            </div>
        }

        <h2>Conversation</h2>
        @if (_chat.Count == 0 && IsActive(_summary.Status))
        {
            <div class="thinking">
                <span class="dot"></span> Waiting for the first message from the agent…
            </div>
        }
        else if (_chat.Count == 0)
        {
            <p class="hint">No conversation captured. The agent may have exited
            before writing its session JSONL — see the live terminal below.</p>
        }
        else
        {
            <div class="chat">
                @{
                    // Pair ToolUse with its matching ToolResult by ToolUseId
                    // so we render ONE log row instead of two stacked cards.
                    // Unpaired ToolResults (rare — would mean orphan output)
                    // are skipped here; the ToolUse renders with no result.
                    var resultsByUseId = _chat.OfType<ChatEvent.ToolResult>()
                        .GroupBy(r => r.ToolUseId)
                        .ToDictionary(g => g.Key, g => g.First());
                }
                @foreach (var evt in _chat)
                {
                    @switch (evt)
                    {
                        case ChatEvent.UserText u:
                            <div class="chat-msg chat-user">
                                <div class="chat-label">You</div>
                                <div class="chat-body">@u.Text</div>
                            </div>
                            break;
                        case ChatEvent.AssistantText a:
                            <div class="chat-msg chat-assistant">
                                <div class="chat-label">Claude</div>
                                <div class="chat-body">@a.Text</div>
                            </div>
                            break;
                        case ChatEvent.Thinking t:
                            <details class="chat-msg chat-thinking">
                                <summary>Claude thought (@t.Text.Length chars)</summary>
                                <div class="chat-body">@t.Text</div>
                            </details>
                            break;
                        case ChatEvent.ToolUse tu:
                            <ToolRow Use="tu" Result="@(resultsByUseId.TryGetValue(tu.ToolId, out var r) ? r : null)" />
                            break;
                        case ChatEvent.ToolResult:
                            // Rendered inline with its ToolUse above; skip.
                            break;
                        case ChatEvent.Meta m:
                            <div class="chat-msg chat-meta">
                                <span class="chat-label">@m.Tag</span>
                                @if (!string.IsNullOrEmpty(m.Detail))
                                {
                                    <span class="chat-body">@m.Detail</span>
                                }
                            </div>
                            break;
                    }
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_finalOutput))
        {
            <details class="output-toggle">
                <summary>Final output (distilled)</summary>
                <pre class="final-output">@_finalOutput</pre>
            </details>
        }

        @if (_lines.Count > 0)
        {
            <details class="raw-toggle">
                <summary>Events (debug, @_lines.Count)</summary>
                <div class="log">
                    @foreach (var line in _lines)
                    {
                        <div class="@LineClass(line)">@line.Text</div>
                    }
                </div>
            </details>
        }

        <details class="output-toggle" open>
            <summary>Live terminal</summary>
            <XtermViewer @ref="_xterm" />
        </details>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private RunRecord? _summary;
    private RunStreamClient? _stream;
    private CancellationTokenSource? _cts;
    private readonly List<LogLine> _lines = new();
    private readonly List<ChatEvent> _chat = new();
    private XtermViewer? _xterm;
    private string? _finalOutput;
    private QuestionSurface? _currentQuestion;
    private string _freeformResponse = "";

    protected override async Task OnInitializedAsync()
    {
        _summary = await Api.GetRunAsync(Id);
        if (_summary is null)
        {
            Nav.NavigateTo("runs");
            return;
        }

        _cts = new CancellationTokenSource();
        var hostBase = Http.BaseAddress ?? new Uri(Nav.BaseUri);
        var hubUrl = new Uri(hostBase, "hub/runs").ToString();
        _stream = new RunStreamClient(hubUrl);
        await _stream.StartAsync(_cts.Token);

        // Two consumers, one per server-side stream method.
        _ = Task.Run(() => ConsumeEventsAsync(_cts.Token));
        _ = Task.Run(() => ConsumeChatAsync(_cts.Token));
    }

    private async Task ConsumeEventsAsync(CancellationToken ct)
    {
        try
        {
            await foreach (var evt in _stream!.StreamAsync(Id, ct))
            {
                await AppendAsync(evt);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _lines.Add(new LogLine($"[stream error] {ex.Message}", LineKind.Error));
            await InvokeAsync(StateHasChanged);
        }
        _summary = await Api.GetRunAsync(Id);
        try { _finalOutput = await Api.GetOutputAsync(Id); } catch { }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConsumeChatAsync(CancellationToken ct)
    {
        try
        {
            await foreach (var evt in _stream!.StreamChatAsync(Id, ct))
            {
                _chat.Add(evt);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _chat.Add(new ChatEvent.Meta(DateTimeOffset.UtcNow, "", "stream-error", ex.Message));
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AppendAsync(AgentEvent evt)
    {
        switch (evt)
        {
            case AgentEvent.Started s:
                _lines.Add(new LogLine($"[{s.AgentName}] started", LineKind.Phase));
                break;
            case AgentEvent.StreamChunk c:
                if (_xterm is not null) await _xterm.WriteAsync(c.Chunk);
                break;
            case AgentEvent.DialogDismissed d:
                _lines.Add(new LogLine($"[{d.AgentName}] dismissed dialog: {d.Match}", LineKind.Phase));
                break;
            case AgentEvent.Completed done:
                _lines.Add(new LogLine($"[{done.AgentName}] completed (exit {done.ExitCode}, {done.OutputChars} chars)", LineKind.Phase));
                break;
            case AgentEvent.Failed fail:
                _lines.Add(new LogLine($"[{fail.AgentName}] FAILED: {fail.Reason}", LineKind.Error));
                break;
            case AgentEvent.Phase phase:
                var kind = phase.Status switch
                {
                    PhaseStatus.Ok   => LineKind.Phase,
                    PhaseStatus.Fail => LineKind.Error,
                    _                => LineKind.Phase,
                };
                _lines.Add(new LogLine($"[{phase.AgentName}] {phase.Status}: {phase.Detail}", kind));
                break;
        }
    }

    private async Task CancelAsync()
    {
        await Api.CancelRunAsync(Id);
    }

    private async Task RespondAsync(string choice)
    {
        if (_currentQuestion is null || string.IsNullOrWhiteSpace(choice)) return;
        await Api.RespondAsync(Id, new RespondRequest(_currentQuestion.CorrelationId, choice));
        _currentQuestion = null;
        _freeformResponse = "";
    }

    private static bool IsActive(RunStatus status) =>
        status is RunStatus.Pending or RunStatus.Starting or RunStatus.Running;

    public async ValueTask DisposeAsync()
    {
        try { _cts?.Cancel(); } catch { }
        if (_stream is not null) await _stream.DisposeAsync();
        _cts?.Dispose();
    }

    private sealed record LogLine(string Text, LineKind Kind);
    private enum LineKind { Stream, Phase, Error }
    private sealed record QuestionSurface(string Text, string? CorrelationId);

    private static string LineClass(LogLine l) => l.Kind switch
    {
        LineKind.Stream => "log-line stream",
        LineKind.Phase  => "log-line phase",
        LineKind.Error  => "log-line error",
        _               => "log-line",
    };
}
