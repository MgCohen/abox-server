@implements IAsyncDisposable
@inject IJSRuntime JS

<div @ref="_host" class="xterm-host"></div>

@code {
    private ElementReference _host;
    private IJSObjectReference? _module;
    private int _handle;
    private bool _ready;

    // Queue writes that arrive before the JS module finishes loading. The
    // first StreamChunk often lands within the same render tick as
    // OnAfterRenderAsync(firstRender:true), so we can't assume the term
    // exists when WriteAsync is first called.
    private readonly System.Collections.Generic.Queue<string> _pending = new();
    private readonly object _gate = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/RemoteAgents.UI.Components/js/xterm-viewer.js");
        _handle = await _module.InvokeAsync<int>("create", _host);
        _ready = true;

        string[] drain;
        lock (_gate)
        {
            drain = _pending.ToArray();
            _pending.Clear();
        }
        foreach (var s in drain)
            await _module.InvokeVoidAsync("write", _handle, s);
    }

    public async Task WriteAsync(string chunk)
    {
        if (string.IsNullOrEmpty(chunk)) return;
        if (!_ready || _module is null)
        {
            lock (_gate) _pending.Enqueue(chunk);
            return;
        }
        await _module.InvokeVoidAsync("write", _handle, chunk);
    }

    public async Task FitAsync()
    {
        if (!_ready || _module is null) return;
        await _module.InvokeVoidAsync("fit", _handle);
    }

    public async Task ClearAsync()
    {
        if (!_ready || _module is null) return;
        await _module.InvokeVoidAsync("clear", _handle);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose", _handle); } catch { }
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
